[revolut]
api_key = TU_API_KEY_AQUI

[signing]
private_pem_path = private.pem

[telegram]
enabled = true
token   = TU_TOKEN_AQUI
chat_id = TU_CHAT_ID_AQUI

[grid]
levels_below = 3
levels_above = 3
base_size = 10
step_percent = 0.5
trailing_up = off  # trailing_up admite: off, on, extended, fixed_quote
trailing_down = off  # trailing_down admite: off, on, extended
bot_usdc_budget = 1000
